# Python
__pycache__/
*.pyc
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Code editors
.idea/

# Env files
.env
.env *
".env *"

# Agentic demo run artifacts
agentic-*/demo_runs/
agentic-*/investigator.log

# Local workspaces — not committed
agents/
agentic-tests/

# Hopsworks demo: per-project SSL certs downloaded by hopsworks-Python at runtime
hopsworks/hopsworks-secrets/*
!hopsworks/hopsworks-secrets/.gitkeep
hopsworks/fraud_streaming_model

# rolling-aggregate-bench: experiment outputs, plots, data, local venv, and local test scripts
rolling-aggregate-bench/experiments/
rolling-aggregate-bench/results*.txt
rolling-aggregate-bench/data/*/
!rolling-aggregate-bench/data/0.01x/
rolling-aggregate-bench/data/0.01x/.cache/
rolling-aggregate-bench/.venv/
rolling-aggregate-bench/test_*.py
rolling-aggregate-bench/tests/
rolling-aggregate-bench/eval/

# agentic-tokens-demo: regenerable artifacts — generated dataset (too big for git), run outputs
# (metrics/score/plots), and the composed schema files (re-derived from generated/<engine>.sql by
# `gen_demo_data.py --schema-only`). The per-engine DETECTORS generated/<engine>.sql ARE committed.
agentic-tokens-demo/data/
agentic-tokens-demo/results/
agentic-tokens-demo/generated/schema.*.sql
agentic-tokens-demo/1.txt
agentic-tokens-demo/*.png
